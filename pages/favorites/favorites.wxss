/* favorites.wxss */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

.header {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}

.favorites-list {
  margin-bottom: 120rpx;
}

.recipes {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.recipe-card {
  transition: transform 0.2s, box-shadow 0.2s;
}

.recipe-card:active {
  transform: scale(0.98);
  box-shadow: 0 16rpx 32rpx rgba(170, 69, 0, 0.1);
}

.empty-state {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.text-6xl {
  font-size: 96rpx;
}

.py-20 {
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .recipes {
    grid-template-columns: repeat(2, 1fr);
  }
}