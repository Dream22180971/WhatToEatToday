<!-- favorites.wxml -->
<view class="container">
  <!-- 头部区域 -->
  <view class="header flex justify-between items-center mb-8">
    <view class="flex items-center gap-4">
      <text class="material-symbols-outlined text-primary">menu</text>
    </view>
    <h1 class="font-headline text-lg font-bold text-primary">我的收藏</h1>
    <button bindtap="toggleEditMode" class="text-primary">
      <text class="material-symbols-outlined">{{editMode ? 'check' : 'edit'}}</text>
    </button>
  </view>

  <!-- 分类筛选 -->
  <view wx:if="{{favorites.length > 0}}" class="category-filter mb-8">
    <h3 class="font-headline text-lg font-bold mb-4">分类筛选</h3>
    <view class="flex flex-wrap gap-3">
      <view class="tag {{selectedCategory === 'all' ? 'tag-secondary' : 'tag-surface'}}" bindtap="selectCategory" data-category="all">
        <text>全部</text>
      </view>
      <block wx:for="{{categories}}" wx:key="index">
        <view class="tag {{selectedCategory === item ? 'tag-secondary' : 'tag-surface'}}" bindtap="selectCategory" data-category="{{item}}">
          <text>{{item}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 批量操作栏 -->
  <view wx:if="{{favorites.length > 0 && editMode}}" class="batch-actions flex justify-between items-center mb-6">
    <text class="text-on-surface-variant">已选择 {{selectedCount}} 项</text>
    <view class="flex gap-4">
      <button class="btn-secondary" bindtap="selectAll">
        <text>全选</text>
      </button>
      <button class="btn-primary" bindtap="batchRemove">
        <text>删除</text>
      </button>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="favorites-list">
    <block wx:if="{{filteredFavorites.length > 0}}">
      <view class="recipes grid grid-cols-1 gap-6">
        <block wx:for="{{filteredFavorites}}" wx:key="id">
          <view class="recipe-card card" bindtap="navigateToDetail" data-id="{{item.id}}">
            <view class="relative h-48 rounded-lg overflow-hidden mb-4">
              <image src="{{item.image}}" mode="cover" class="w-full h-full"></image>
              <view class="absolute top-3 left-3 bg-surface/80 backdrop-blur-md px-3 py-1 rounded-full flex items-center gap-2">
                <text class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">local_fire_department</text>
                <text class="text-xs font-bold uppercase text-on-surface">{{item.tags[0]}}</text>
              </view>
              <button class="absolute top-3 right-3 w-10 h-10 rounded-full bg-surface/80 backdrop-blur-md flex items-center justify-center" bindtap="removeFavorite" data-id="{{item.id}}" catchtap="preventPropagation">
                <text class="material-symbols-outlined text-red-500" style="font-variation-settings: 'FILL' 1;">favorite</text>
              </button>
              <view wx:if="{{editMode}}" class="absolute top-3 left-36">
                <checkbox value="{{item.id}}" checked="{{selectedItems.includes(item.id)}}" bindchange="toggleSelect" data-id="{{item.id}}" catchtap="preventPropagation" />
              </view>
            </view>
            <view class="p-4">
              <h4 class="font-headline text-lg font-bold mb-2">{{item.title}}</h4>
              <view class="flex justify-between items-center">
                <view class="flex items-center gap-4">
                  <view class="flex items-center gap-1 text-on-surface-variant">
                    <text class="material-symbols-outlined text-sm">schedule</text>
                    <text class="text-xs font-medium">{{item.time}}</text>
                  </view>
                  <view class="flex items-center gap-1 text-on-surface-variant">
                    <text class="material-symbols-outlined text-sm">restaurant</text>
                    <text class="text-xs font-medium">{{item.category}}</text>
                  </view>
                </view>
                <view class="text-on-surface-variant text-xs font-medium">{{item.calories}}</view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </block>
    <block wx:else>
      <view class="empty-state flex flex-col items-center justify-center py-20">
        <text class="material-symbols-outlined text-6xl text-on-surface-variant mb-4">favorite_border</text>
        <h2 class="font-headline text-xl font-bold mb-2">{{favorites.length > 0 ? '没有符合条件的收藏' : '还没有收藏'}}</h2>
        <p class="text-on-surface-variant text-center mb-8">{{favorites.length > 0 ? '尝试选择其他分类' : '开始添加你喜欢的食谱吧'}}</p>
        <button wx:if="{{favorites.length === 0}}" class="btn-primary" bindtap="navigateToHome">
          <text>探索食谱</text>
        </button>
      </view>
    </block>
  </view>
</view>