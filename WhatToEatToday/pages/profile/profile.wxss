/* profile.wxss */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

.header {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}

.user-info {
  margin-bottom: 32rpx;
}

.w-24 {
  width: 96rpx;
}

.h-24 {
  height: 96rpx;
}

.border-4 {
  border-width: 16rpx;
}

.border-white {
  border-color: white;
}

.shadow-md {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  background-color: var(--surface-container);
  border-radius: 32rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.text-2xl {
  font-size: 32rpx;
}

.settings {
  margin-bottom: 48rpx;
}

.settings-list {
  background-color: var(--surface-container);
  border-radius: 32rpx;
  overflow: hidden;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(187, 185, 179, 0.2);
}

.setting-item:last-child {
  border-bottom: none;
}

.border-b {
  border-bottom: 1rpx solid;
}

.border-outline-variant-20 {
  border-color: rgba(187, 185, 179, 0.2);
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .w-24 {
    width: 80rpx;
  }
  
  .h-24 {
    height: 80rpx;
  }
  
  .border-4 {
    border-width: 12rpx;
  }
  
  .text-2xl {
    font-size: 28rpx;
  }
}