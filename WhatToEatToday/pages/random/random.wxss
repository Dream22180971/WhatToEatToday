/* random.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  width: 100%;
}

.text-center {
  text-align: center;
  margin-bottom: 48rpx;
}

.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.inset-0 {
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.z-10 {
  z-index: 10;
}

.rotate-3 {
  transform: rotate(3deg);
}

.-rotate-2 {
  transform: rotate(-2deg);
}

.translate-x-2 {
  transform: translateX(8rpx);
}

.-translate-x-1 {
  transform: translateX(-4rpx);
}

.translate-y-2 {
  transform: translateY(8rpx);
}

.-translate-y-1 {
  transform: translateY(-4rpx);
}

.-right-4 {
  right: -16rpx;
}

.top-12 {
  top: 50%;
}

.-translate-y-12 {
  transform: translateY(-50%);
}

.opacity-50 {
  opacity: 0.5;
}

.opacity-70 {
  opacity: 0.7;
}

.shadow-lg {
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.blur-80px {
  filter: blur(80rpx);
}

.aspect-square {
  aspect-ratio: 1;
}

.w-72 {
  width: 288rpx;
}

.h-96 {
  height: 384rpx;
}

.h-64 {
  height: 256rpx;
}

.w-8 {
  width: 32rpx;
}

.h-12 {
  height: 48rpx;
}

.rounded-l-full {
  border-top-left-radius: 9999rpx;
  border-bottom-left-radius: 9999rpx;
}

.gap-1 {
  gap: 4rpx;
}

.mb-16 {
  margin-bottom: 64rpx;
}

.mb-10 {
  margin-bottom: 40rpx;
}

.mt-12 {
  margin-top: 48rpx;
}

/* 动画效果 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.spin {
  animation: spin 2s linear infinite;
}

/* 卡片动画 */
@keyframes flip {
  0% {
    transform: rotateY(0deg);
  }
  50% {
    transform: rotateY(90deg);
  }
  100% {
    transform: rotateY(0deg);
  }
}

.flip {
  animation: flip 1s ease-in-out;
}